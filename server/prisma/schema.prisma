// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                        String                    @id @default(uuid())
  email                     String                    @unique
  password                  String
  name                      String?
  avatarUrl                 String?
  coverUrl                  String?
  bio                       String?
  location                  String?
  website                   String?
  role                      String                    @default("USER") // 'USER' or 'ADMIN'
  status                    String                    @default("ACTIVE") // 'ACTIVE' or 'BANNED'
  points                    Int                       @default(50)
  emailVerified             Boolean                   @default(false)
  twoFactorEnabled          Boolean                   @default(false)
  twoFactorSecret           String?
  twoFactorRecoveryCodes    String?                   @db.Text // Hashed JSON string of recovery codes
  defaultWorkspaceId        String?
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt
  assets                    Asset[]
  assetVersions             AssetVersion[]
  assetAnnotations          AssetAnnotation[]
  refreshTokens             RefreshToken[]
  discussions               Discussion[]
  comments                  Comment[]
  enrollments               Enrollment[]
  trustedDevices            TrustedDevice[]
  feedbacks                 Feedback[]
  notifications             Notification[]
  notificationPreference    NotificationPreference?
  tasks                     Task[]
  roadmapProgress           UserRoadmapProgress[]
  roadmaps                  Roadmap[]                 @relation("UserRoadmaps")
  projects                  ProjectMember[]
  materials                 Material[]
  materialFavorites         MaterialFavorite[]
  showcases                 Showcase[]
  showcaseLikes             ShowcaseLike[]
  showcaseComments          ShowcaseComment[]
  discussionLikes           DiscussionLike[]
  commentLikes              CommentLike[]
  projectDiscussions        ProjectDiscussion[]
  projectDiscussionReactions ProjectDiscussionReaction[]
  projectInvitationsReceived ProjectInvitation[]

  // Course learning
  courseReviews             CourseReview[]
  lessonProgress            LessonProgress[]
  courseNotes               CourseNote[]
  noteLikes                 NoteLike[]
  notes                     Note[]
  noteShares                NoteShare[]
  noteComments              NoteComment[]
  taskComments              TaskComment[]

  // Messaging & Teams
  conversations             Conversation[]            @relation("UserConversations")
  messages                  Message[]
  messageReads              MessageRead[]
  messageReactions          MessageReaction[]
  ownedTeams                Team[]                    @relation("TeamOwner")
  teamMemberships           TeamMember[]
  assignedTasks             Task[]                    @relation("TaskAssignee")
  taskParticipants          TaskParticipant[]
  taskActivities            TaskActivity[]
  teamApplications          TeamApplication[]

  // Subscriptions & Billing
  subscription              Subscription?
  transactions              Transaction[]
  activationCodesRedeemed   ActivationCode[]
  userSettings              UserSetting[]
  auditLogs                 AuditLog[]
  mirrorComments            MirrorResourceComment[]
  mirrorLikes               MirrorResourceLike[]
  manualComments            ManualResourceComment[]
  manualLikes               ManualResourceLike[]
  assetComments             AssetComment[]

  googleId                  String?                   @unique
  githubId                  String?                   @unique
  microsoftEmailAccounts    MicrosoftEmailAccount[]
  googleWarmingAccounts     GoogleWarmingAccount[]
  twoFactorAccounts         TwoFactorAccount[]
  aiBotIntegrations         AiBotIntegration[]
  aiBotMessages             AiBotMessage[]
  aiChatSessions            AiChatSession[]
  aiBotKnowledgeSources     AiBotKnowledgeSource[]
  directMessageEmailBatches DirectMessageEmailBatch[]
  aiMessages                AiMessage[]
  plugins                   Plugin[]
  assetLikes                AssetLike[]
  assetShares               AssetShare[]
  materialComments          MaterialComment[]
  pluginComments            PluginComment[]
  materialShares            MaterialShare[]
  pluginShares              PluginShare[]
  pluginRequests            PluginRequest[]
  pluginRequestReplies      PluginRequestReply[]
  pluginFavorites           PluginFavorite[]
  assetRequests             AssetRequest[]
  assetRequestReplies       AssetRequestReply[]
  materialRequests          MaterialRequest[]
  materialRequestReplies    MaterialRequestReply[]
  softwares                 Software[]
  softwareComments          SoftwareComment[]
  softwareShares            SoftwareShare[]
  softwareFavorites         SoftwareFavorite[]
  temporaryFiles            TemporaryFile[]
  temporaryShares           TemporaryShare[]

  // Indexes for frequently-filtered columns (admin user list, dashboard stats)
  @@index([role])
  @@index([status])
  @@index([createdAt])
}

model Conversation {
  id                        String                    @id @default(uuid())
  name                      String?
  avatarUrl                 String?
  isGroup                   Boolean                   @default(false)
  participants              User[]                    @relation("UserConversations")
  messages                  Message[]
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt

  @@index([updatedAt])
}

model Message {
  id                        String                    @id @default(uuid())
  content                   String                    @db.Text
  type                      String                    @default("TEXT")
  senderId                  String
  sender                    User                      @relation(fields: [senderId], references: [id], onDelete: Cascade)
  conversationId            String
  conversation              Conversation              @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  replyToId                 String?
  replyTo                   Message?                  @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies                   Message[]                 @relation("MessageReplies")
  readBy                    MessageRead[]
  reactions                 MessageReaction[]
  createdAt                 DateTime                  @default(now())

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
}

model MessageRead {
  id                        String                    @id @default(uuid())
  messageId                 String
  message                   Message                   @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId                    String
  user                      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  readAt                    DateTime                  @default(now())

  @@unique([messageId, userId])
}

model MessageReaction {
  id                        String                    @id @default(uuid())
  messageId                 String
  message                   Message                   @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId                    String
  user                      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  emoji                     String
  createdAt                 DateTime                  @default(now())

  @@unique([messageId, userId, emoji])
}

model Team {
  id                        String                    @id @default(uuid())
  name                      String
  description               String?                   @db.Text
  avatarUrl                 String?
  coverUrl                  String?
  type                      String                    @default("TEAM") // 'PERSONAL', 'TEAM'
  visibility                String                    @default("PRIVATE") // 'PUBLIC', 'PRIVATE'
  category                  String?
  ownerId                   String
  owner                     User                      @relation("TeamOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members                   TeamMember[]
  invitations               TeamInvitation[]
  applications              TeamApplication[]

  // Associated data
  assets                    Asset[]
  tasks                     Task[]
  projects                  Project[]
  materials                 Material[]
  showcases                 Showcase[]
  enrollments               Enrollment[]

  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt

  // Unique constraint for public space to prevent duplicates
  @@unique([name, type])
  @@index([ownerId])
  @@index([type])
}

model TeamMember {
  id                        String                    @id @default(uuid())
  teamId                    String
  team                      Team                      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId                    String
  user                      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role                      String                    @default("MEMBER") // 'OWNER', 'ADMIN', 'MEMBER'
  joinedAt                  DateTime                  @default(now())

  @@unique([teamId, userId])
  @@index([userId])
}

model TeamInvitation {
  id                        String                    @id @default(uuid())
  teamId                    String
  team                      Team                      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  inviterId                 String
  inviteeEmail              String
  status                    String                    @default("PENDING") // 'PENDING', 'ACCEPTED', 'REJECTED'
  expiresAt                 DateTime
  createdAt                 DateTime                  @default(now())

  @@index([teamId])
  @@index([inviteeEmail])
}

model Notification {
  id                        String                    @id @default(uuid())
  type                      String                    // 'REPLY', 'COURSE_UPDATE', 'SYSTEM'
  title                     String
  content                   String                    @db.LongText
  isRead                    Boolean                   @default(false)
  userId                    String
  user                      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  link                      String?                   // Optional link to redirect user
  broadcastId               String?
  broadcast                 Broadcast?                @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  createdAt                 DateTime                  @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([broadcastId])
}

model NotificationPreference {
  id                        String                    @id @default(uuid())
  userId                    String                    @unique
  user                      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  pushSystemUpdates         Boolean                   @default(true)
  pushTeamActivity          Boolean                   @default(true)
  pushMentions              Boolean                   @default(true)
  pushDirectMessages        Boolean                   @default(true)
  pushMarketing             Boolean                   @default(false)
  emailSystemUpdates        Boolean                   @default(true)
  emailTeamActivity         Boolean                   @default(true)
  emailDirectMessages       Boolean                   @default(true)
  emailMentions             Boolean                   @default(true)
  emailMarketing            Boolean                   @default(false)
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt
}

model Broadcast {
  id                        String                    @id @default(uuid())
  title                     String
  content                   String                    @db.LongText
  link                      String?
  notifications             Notification[]
  createdAt                 DateTime                  @default(now())

  @@index([createdAt])
}

model TrustedDevice {
  id                        String                    @id @default(uuid())
  userId                    String
  user                      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token                     String                    @unique
  userAgent                 String?                   @db.Text
  ipAddress                 String?
  lastUsedAt                DateTime                  @default(now())
  createdAt                 DateTime                  @default(now())

  @@index([userId])
  @@index([userId, lastUsedAt])
}

model RefreshToken {
  id                        String                    @id @default(uuid())
  token                     String                    @unique
  userId                    String
  user                      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt                 DateTime
  createdAt                 DateTime                  @default(now())

  @@index([userId])
}

model UserSetting {
  id                        String                    @id @default(uuid())
  userId                    String
  user                      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  key                       String
  value                     String
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt

  @@unique([userId, key])
}

model SystemSetting {
  id                        String                    @id @default(uuid())
  key                       String                    @unique
  value                     String                    @db.Text
  updatedAt                 DateTime                  @updatedAt
}

model Asset {
  id                        String                    @id @default(uuid())
  title                     String
  description               String?                   @db.Text
  url                       String
  packageUrl                String?
  packageSize               Float?
  packageFilesList          String?                   @db.Text
  thumbnail                 String?
  type                      String                    // e.g., 'GLB', 'GLTF', 'FBX'
  status                    String                    @default("PENDING") // 'PENDING', 'APPROVED', 'REJECTED'
  rejectReason              String?
  formats                   String?                   @db.Text // 瀛樺偍 JSON 瀛楃涓诧紝濡?["FBX", "OBJ"]
  tags                      String?                   @db.Text // JSON string of tag names (e.g., ["scifi", "character"])

  // 鐗堟潈涓庢巿鏉?  originality               String?                   @default("ORIGINAL") // "ORIGINAL", "AUTHORIZED", "REMIX"
  originality               String?                   @default("ORIGINAL")
  originalAuthor            String?
  originalLink              String?
  license                   String?                   @default("CC_BY") // "CC_BY", "CC_BY_NC", etc.

  // 3D 瑙勬牸涓庝紭鍖?  meshType                  String?                   @default("LOW_POLY") // "LOW_POLY", "HIGH_POLY", "CAD"
  meshType                  String?                   @default("LOW_POLY")
  uvUnwrapped               Boolean                   @default(true)
  uvOverlapping             Boolean                   @default(false)
  pbrChannels               String?                   @db.Text // JSON string of selected channels
  rigged                    Boolean                   @default(false)
  gameReady                 Boolean                   @default(false)

  // 3D 瑙嗗彛鍒濆鍖栭厤缃?  defaultCameraPos          String?                   // JSON string
  defaultCameraPos          String?                   // JSON string
  defaultCameraTarget       String?                   // JSON string
  defaultEnvironment        String?                   @default("studio")
  defaultExposure           Float?                    @default(1.0)

  // Association with a course and its lesson.
  linkedCourseId            String?
  linkedCourse              Course?                   @relation("CourseAssets", fields: [linkedCourseId], references: [id], onDelete: SetNull)
  linkedLessonId            String?
  linkedLesson              Lesson?                   @relation("LessonAssets", fields: [linkedLessonId], references: [id], onDelete: SetNull)

  // 3D Metadata
  vertices                  Int?
  faces                     Int?
  materials                 Int?
  animations                Int?
  hasAnimations             Boolean                   @default(false)
  size                      Float?                    // in MB
  dimensions                String?                   // e.g., "10x20x15"
  maxTextureRes             Int?
  downloads                 Int                       @default(0)
  likes                     Int                       @default(0)
  viewCount                 Int                       @default(0)
  bilibiliUrl               String?

  categoryId                String?
  category                  Category?                 @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  userId                    String
  user                      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamId                    String?
  team                      Team?                     @relation(fields: [teamId], references: [id], onDelete: SetNull)
  showcases                 Showcase[]
  linkedShowcases           Showcase[]                @relation("ShowcaseLinkedAssets")
  versions                  AssetVersion[]
  annotations               AssetAnnotation[]
  likesRelation             AssetLike[]
  isFree                    Boolean                   @default(true)
  assetShare                AssetShare?
  comments                  AssetComment[]
  linkedReplies             AssetRequestReply[]
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt

  @@index([userId])
  @@index([categoryId])
  @@index([teamId])
  @@index([status, type, createdAt])
  @@index([size])
  @@index([type])
  @@index([linkedCourseId])
  @@index([linkedLessonId])
}

model Category {
  id                        String                    @id @default(uuid())
  name                      String                    @unique
  icon                      String?
  order                     Int                       @default(0)
  assets                    Asset[]
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt
}

model Course {
  id                        String                    @id @default(uuid())
  title                     String
  description               String?
  thumbnail                 String?
  difficulty                String                    @default("BEGINNER") // 'BEGINNER', 'INTERMEDIATE', 'ADVANCED'
  status                    String                    @default("PUBLISHED") // 'DRAFT', 'PUBLISHED'
  lessons                   Lesson[]
  enrollments               Enrollment[]
  linkedAssets              Asset[]                   @relation("CourseAssets")
  linkedMaterials           Material[]                @relation("CourseMaterials")
  linkedPlugins             Plugin[]                  @relation("CoursePlugins")
  linkedSoftwares           Software[]                @relation("CourseSoftwares")
  discussions               Discussion[]
  reviews                   CourseReview[]
  categoryId                String?
  category                  CourseCategory?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt

  @@index([status])
  @@index([categoryId])
}

model CourseCategory {
  id                        String                    @id @default(uuid())
  name                      String                    @unique
  order                     Int                       @default(0)
  courses                   Course[]
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt
}

model Lesson {
  id                        String                    @id @default(uuid())
  title                     String
  content                   String?                   // Markdown or HTML
  videoUrl                  String?
  hotspots                  String?                   // JSON string for 3D hotspots
  sceneConfig               String?                   // JSON string for environment, lighting, post-processing
  duration                  Int                       @default(0) // Duration in minutes
  courseId                  String
  course                    Course                    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  order                     Int
  progress                  LessonProgress[]
  notes                     CourseNote[]
  linkedAssets              Asset[]                   @relation("LessonAssets")
  linkedMaterials           Material[]                @relation("LessonMaterials")
  linkedPlugins             Plugin[]                  @relation("LessonPlugins")
  linkedSoftwares           Software[]                @relation("LessonSoftwares")
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt

  @@index([courseId])
  @@index([courseId, order])
}

model Enrollment {
  id                        String                    @id @default(uuid())
  userId                    String
  user                      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId                  String
  course                    Course                    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teamId                    String?
  team                      Team?                     @relation(fields: [teamId], references: [id], onDelete: SetNull)
  progress                  Float                     @default(0)
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt

  @@unique([userId, courseId, teamId])
  @@index([courseId])
  @@index([userId])
  @@index([teamId])
}

model Discussion {
  id                        String                    @id @default(uuid())
  title                     String
  content                   String                    @db.Text
  images                    String?                   @db.Text // JSON array of image URLs
  tags                      String?                   @db.Text // JSON array of tag names
  userId                    String
  user                      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId                  String?                   // Optional: link to a course
  course                    Course?                   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  isPinned                  Boolean                   @default(false)
  viewCount                 Int                       @default(0)
  comments                  Comment[]
  likes                     DiscussionLike[]
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt

  @@index([userId])
  @@index([courseId])
  @@index([createdAt])
}

model DiscussionLike {
  id                        String                    @id @default(uuid())
  discussionId              String
  discussion                Discussion                @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  userId                    String
  user                      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt                 DateTime                  @default(now())

  @@unique([discussionId, userId])
  @@index([userId])
}

model Comment {
  id                        String                    @id @default(uuid())
  content                   String                    @db.Text
  userId                    String
  user                      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  discussionId              String
  discussion                Discussion                @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  parentId                  String?
  parent                    Comment?                  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies                   Comment[]                 @relation("CommentReplies")
  likes                     CommentLike[]
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt

  @@index([userId])
  @@index([discussionId])
  @@index([parentId])
}

model CommentLike {
  id                        String                    @id @default(uuid())
  commentId                 String
  comment                   Comment                   @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId                    String
  user                      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt                 DateTime                  @default(now())

  @@unique([commentId, userId])
  @@index([userId])
}

model Task {
  id                        String                    @id @default(uuid())
  title                     String
  description               String?                   @db.Text
  status                    String                    // 'TODO', 'IN_PROGRESS', 'DONE'
  priority                  String                    @default("MEDIUM") // 'LOW', 'MEDIUM', 'HIGH', 'URGENT'
  tags                      String?                   @db.Text // JSON string of tag names
  subtasks                  String?                   @db.Text // JSON string of [{ id: string, text: string, done: boolean }]
  dueDate                   DateTime?
  userId                    String
  user                      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  assigneeId                String?
  assignee                  User?                     @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  teamId                    String?
  team                      Team?                     @relation(fields: [teamId], references: [id], onDelete: SetNull)
  projectId                 String?
  project                   Project?                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  participants              TaskParticipant[]
  comments                  TaskComment[]
  timeEstimate              Int                       @default(0)
  timeSpent                 Int                       @default(0)
  dependencies              TaskDependency[]          @relation("TaskDeps")
  dependents                TaskDependency[]          @relation("TaskBlockedBy")
  activities                TaskActivity[]
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt

  @@index([userId])
  @@index([assigneeId])
  @@index([teamId])
  @@index([projectId])
}

model TaskParticipant {
  id                        String                    @id @default(uuid())
  taskId                    String
  task                      Task                      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId                    String
  user                      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt                  DateTime                  @default(now())

  @@unique([taskId, userId])
  @@index([userId])
}

model TaskComment {
  id                        String                    @id @default(uuid())
  content                   String                    @db.Text
  taskId                    String
  task                      Task                      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId                    String
  user                      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt

  @@index([taskId])
  @@index([userId])
}

model TaskDependency {
  id                        String                    @id @default(uuid())
  taskId                    String
  task                      Task                      @relation("TaskDeps", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOnId               String
  dependsOn                 Task                      @relation("TaskBlockedBy", fields: [dependsOnId], references: [id], onDelete: Cascade)
  createdAt                 DateTime                  @default(now())

  @@unique([taskId, dependsOnId])
  @@index([taskId])
  @@index([dependsOnId])
}

model TaskActivity {
  id                        String                    @id @default(uuid())
  taskId                    String
  task                      Task                      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId                    String
  user                      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  action                    String                    // e.g., 'CREATE', 'UPDATE_STATUS', 'UPDATE_ASSIGNEE', etc.
  description               String                    // Human-readable description
  oldValue                  String?                   @db.Text
  newValue                  String?                   @db.Text
  createdAt                 DateTime                  @default(now())

  @@index([taskId])
  @@index([userId])
}

model TeamApplication {
  id                        String                    @id @default(uuid())
  teamId                    String
  team                      Team                      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId                    String
  user                      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  message                   String?
  status                    String                    @default("PENDING") // 'PENDING', 'APPROVED', 'REJECTED'
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt

  @@unique([teamId, userId])
  @@index([userId])
}

model Feedback {
  id                        String                    @id @default(uuid())
  type                      String                    // 'Bug', 'Feature', 'UI', 'Other'
  title                     String
  description               String
  priority                  String                    // 'LOW', 'MEDIUM', 'HIGH'
  status                    String                    @default("OPEN") // 'OPEN', 'IN_PROGRESS', 'RESOLVED', 'CLOSED'
  attachmentUrl             String?
  adminReply                String?                   // Admin's response
  repliedAt                 DateTime?
  adminId                   String?                   // ID of the admin who replied

  userId                    String
  user                      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt

  @@index([userId])
  @@index([status])
}

model VerificationCode {
  id                        String                    @id @default(uuid())
  email                     String
  code                      String
  expiresAt                 DateTime
  createdAt                 DateTime                  @default(now())

  @@index([email])
}

model Roadmap {
  id                        String                    @id @default(uuid())
  title                     String
  description               String?                   @db.Text
  steps                     RoadmapStep[]
  creatorId                 String?
  creator                   User?                     @relation("UserRoadmaps", fields: [creatorId], references: [id], onDelete: Cascade)
  projectId                 String?                   @unique
  project                   Project?                  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt

  @@index([creatorId])
}

model RoadmapStep {
  id                        String                    @id @default(uuid())
  title                     String
  description               String?                   @db.Text
  subtasks                  String?                   @db.Text
  order                     Int
  roadmapId                 String
  roadmap                   Roadmap                   @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  userProgress              UserRoadmapProgress[]
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt

  @@index([roadmapId])
}

model UserRoadmapProgress {
  id                        String                    @id @default(uuid())
  userId                    String
  user                      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  roadmapStepId             String
  roadmapStep               RoadmapStep               @relation(fields: [roadmapStepId], references: [id], onDelete: Cascade)
  completed                 Boolean                   @default(false)
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt

  @@unique([userId, roadmapStepId])
  @@index([roadmapStepId])
}

model Project {
  id                        String                    @id @default(uuid())
  title                     String
  description               String?                   @db.Text
  progress                  Int                       @default(0)
  status                    String                    @default("IN_PROGRESS") // 'IN_PROGRESS', 'COMPLETED', 'PAUSED'
  dueDate                   DateTime?
  color                     String                    @default("bg-accent")
  tags                      String?                   @db.Text // JSON string or comma separated
  visibility                String                    @default("PRIVATE") // 'PUBLIC', 'PRIVATE' (Team internal)
  maxMembers                Int                       @default(10)
  members                   ProjectMember[]
  tasks                     Task[]
  discussions               ProjectDiscussion[]
  invitations               ProjectInvitation[]
  roadmap                   Roadmap?
  teamId                    String?
  team                      Team?                     @relation(fields: [teamId], references: [id], onDelete: SetNull)
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt

  @@index([teamId])
}

model ProjectMember {
  id                        String                    @id @default(uuid())
  projectId                 String
  project                   Project                   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId                    String
  user                      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role                      String                    @default("MEMBER") // 'OWNER', 'MEMBER'
  joinedAt                  DateTime                  @default(now())

  @@unique([projectId, userId])
  @@index([userId])
}

model ProjectDiscussion {
  id                        String                    @id @default(uuid())
  content                   String                    @db.Text
  type                      String                    @default("TEXT")
  images                    String?                   @db.Text
  fileUrl                   String?
  fileName                  String?
  fileSize                  Float?
  projectId                 String
  project                   Project                   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId                    String
  user                      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  reactions                 ProjectDiscussionReaction[]
  createdAt                 DateTime                  @default(now())

  @@index([projectId])
  @@index([projectId, createdAt])
}

model ProjectDiscussionReaction {
  id                        String                    @id @default(uuid())
  discussionId              String
  discussion                ProjectDiscussion         @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  userId                    String
  user                      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  emoji                     String
  createdAt                 DateTime                  @default(now())

  @@unique([discussionId, userId, emoji])
  @@index([discussionId])
}

model ProjectInvitation {
  id                        String                    @id @default(uuid())
  projectId                 String
  project                   Project                   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  inviterId                 String
  inviteeId                 String
  invitee                   User                      @relation(fields: [inviteeId], references: [id], onDelete: Cascade)
  status                    String                    @default("PENDING")
  expiresAt                 DateTime
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt

  @@index([projectId, inviteeId])
}

model Material {
  id                        String                    @id @default(uuid())
  title                     String
  description               String?                   @db.Text
  category                  String
  resolution                String?                   // '4K', '8K', '鐭㈤噺', etc.
  previewUrl                String?
  fileUrl                   String
  fileSize                  Float?                    // in MB
  packageFilesList          String?                   @db.Text
  tags                      String?                   @db.Text
  isProcedural              Boolean                   @default(false)
  downloads                 Int                       @default(0)
  status                    String                    @default("PENDING") // 'PENDING', 'APPROVED', 'REJECTED'
  rejectReason              String?
  userId                    String
  user                      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamId                    String?
  team                      Team?                     @relation(fields: [teamId], references: [id], onDelete: SetNull, map: "Material_teamId_fk")
  favorites                 MaterialFavorite[]
  comments                  MaterialComment[]
  linkedReplies             MaterialRequestReply[]
  materialShare             MaterialShare?
  linkedShowcases           Showcase[]                @relation("ShowcaseLinkedMaterials")
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt
  bilibiliUrl               String?

  // 鐗堟潈涓庢巿鏉?  originality               String?                   @default("ORIGINAL")
  originality               String?                   @default("ORIGINAL")
  originalAuthor            String?
  originalLink              String?
  license                   String?                   @default("CC_BY")
  isFree                    Boolean                   @default(true)

  // Association with a course and its lesson.
  linkedCourseId            String?
  linkedCourse              Course?                   @relation("CourseMaterials", fields: [linkedCourseId], references: [id], onDelete: SetNull)
  linkedLessonId            String?
  linkedLesson              Lesson?                   @relation("LessonMaterials", fields: [linkedLessonId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([teamId])
  @@index([status])
  @@index([category])
  @@index([linkedCourseId])
  @@index([linkedLessonId])
}

model MaterialFavorite {
  id                        String                    @id @default(uuid())
  userId                    String
  user                      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  materialId                String
  material                  Material                  @relation(fields: [materialId], references: [id], onDelete: Cascade)
  category                  String                    @default("榛樿")
  createdAt                 DateTime                  @default(now())

  @@unique([userId, materialId])
}

model Showcase {
  id                        String                    @id @default(uuid())
  title                     String
  description               String?                   @db.Text
  tags                      String?                   @db.Text
  type                      String                    @default("IMAGE") // 'IMAGE', 'VIDEO', 'MODEL', 'OTHER'
  thumbnailUrl              String
  images                    String?                   @db.Text // JSON array of image URLs
  videoUrl                  String?
  isVideo                   Boolean                   @default(false)
  views                     Int                       @default(0)
  status                    String                    @default("PENDING") // 'PENDING', 'APPROVED', 'REJECTED'
  assetId                   String?                   // Optional link to Asset
  asset                     Asset?                    @relation(fields: [assetId], references: [id], onDelete: SetNull)
  userId                    String
  user                      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamId                    String?
  team                      Team?                     @relation(fields: [teamId], references: [id], onDelete: SetNull)
  likes                     ShowcaseLike[]
  comments                  ShowcaseComment[]
  linkedAssets              Asset[]                   @relation("ShowcaseLinkedAssets")
  linkedMaterials           Material[]                @relation("ShowcaseLinkedMaterials")
  linkedPlugins             Plugin[]                  @relation("ShowcaseLinkedPlugins")
  linkedSoftwares           Software[]                @relation("ShowcaseLinkedSoftwares")
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt

  @@index([assetId])
  @@index([userId])
  @@index([teamId])
  @@index([status])
}

model ShowcaseLike {
  id                        String                    @id @default(uuid())
  showcaseId                String
  showcase                  Showcase                  @relation(fields: [showcaseId], references: [id], onDelete: Cascade)
  userId                    String
  user                      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt                 DateTime                  @default(now())

  @@unique([showcaseId, userId])
  @@index([userId])
}

model ShowcaseComment {
  id                        String                    @id @default(uuid())
  content                   String
  showcaseId                String
  showcase                  Showcase                  @relation(fields: [showcaseId], references: [id], onDelete: Cascade)
  userId                    String
  user                      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt

  @@index([showcaseId, userId])
}

model SubscriptionPlan {
  id                        String                    @id @default(uuid())
  name                      String                    @unique
  displayName               String?
  price                     Float
  yearlyPrice               Float?
  interval                  String                    @default("MONTHLY")
  features                  String?
  maxStorage                Float                     @default(1)
  maxTeams                  Int                       @default(1)
  maxProjects               Int                       @default(5)
  maxAssets                 Int                       @default(50)
  priority                  Int                       @default(0)
  isPopular                 Boolean                   @default(false)
  badgeColor                String?
  subscriptions             Subscription[]
  activationCodes           ActivationCode[]
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt
}

model Subscription {
  id                        String                    @id @default(uuid())
  userId                    String                    @unique
  user                      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId                    String
  plan                      SubscriptionPlan          @relation(fields: [planId], references: [id])
  status                    String                    @default("ACTIVE")
  interval                  String                    @default("MONTHLY")
  startDate                 DateTime                  @default(now())
  endDate                   DateTime?
  cancelAtPeriodEnd         Boolean                   @default(false)
  autoRenew                 Boolean                   @default(true)
  paymentMethod             String?
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt

  @@index([planId])
  @@index([status])
}

model ActivationCode {
  id                        String                    @id @default(uuid())
  code                      String                    @unique
  planId                    String
  plan                      SubscriptionPlan          @relation(fields: [planId], references: [id], onDelete: Cascade)
  durationDays              Int                       @default(30)
  status                    String                    @default("ACTIVE") // 'ACTIVE', 'USED', 'EXPIRED'
  usedById                  String?
  usedBy                    User?                     @relation(fields: [usedById], references: [id], onDelete: SetNull)
  usedAt                    DateTime?
  expiresAt                 DateTime?
  bindEmail                 String?
  description               String?
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt

  @@index([planId])
  @@index([usedById])
}

model Transaction {
  id                        String                    @id @default(uuid())
  userId                    String
  user                      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount                    Float
  currency                  String                    @default("CNY")
  status                    String                    @default("PENDING") // 'PENDING', 'COMPLETED', 'FAILED', 'REFUNDED'
  paymentMethod             String?                   // 'ALIPAY', 'WECHAT', 'MOCK'
  paymentId                 String?                   @unique // Third-party payment ID
  description               String?
  planId                    String?
  planName                  String?
  interval                  String?
  invoiceNo                 String?                   @unique
  metadata                  String?                   // JSON string for additional data
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @default(now()) @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model CourseReview {
  id                        String                    @id @default(uuid())
  userId                    String
  user                      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId                  String
  course                    Course                    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  rating                    Int                       // 1-5
  comment                   String?
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt

  @@unique([userId, courseId])
  @@index([courseId])
  @@index([rating])
}

model LessonProgress {
  id                        String                    @id @default(uuid())
  userId                    String
  user                      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId                  String
  lesson                    Lesson                    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  completed                 Boolean                   @default(false)
  completedAt               DateTime?
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt

  @@unique([userId, lessonId])
  @@index([userId])
}

model CourseNote {
  id                        String                    @id @default(uuid())
  userId                    String
  user                      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId                  String
  lesson                    Lesson                    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  content                   String
  timestamp                 Int?
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt

  @@index([userId, lessonId])
  @@index([lessonId])
}

model Note {
  id                        String                    @id @default(uuid())
  title                     String
  content                   String                    @db.Text
  summary                   String?
  visibility                String                    @default("PRIVATE")
  tags                      String?
  category                  String?
  views                     Int                       @default(0)
  isPinned                  Boolean                   @default(false)
  isPopular                 Boolean                   @default(false)
  userId                    String
  user                      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes                     NoteLike[]
  comments                  NoteComment[]
  noteShare                 NoteShare?
  knowledgeGraph            KnowledgeGraph?
  isGithub                  Boolean                   @default(false)
  githubRepo                String?
  githubBranch              String?
  githubPath                String?
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt

  @@index([userId])
  @@index([category])
  @@index([visibility, isPopular])
  @@index([isPinned])
  @@index([githubRepo, githubPath])
}

model NoteLike {
  noteId                    String
  note                      Note                      @relation(fields: [noteId], references: [id], onDelete: Cascade)
  userId                    String
  user                      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt                 DateTime                  @default(now())

  @@id([noteId, userId])
}

model NoteComment {
  id                        String                    @id @default(uuid())
  content                   String                    @db.Text
  noteId                    String
  note                      Note                      @relation(fields: [noteId], references: [id], onDelete: Cascade)
  userId                    String
  user                      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt

  @@index([noteId])
  @@index([userId])
}

model AuditLog {
  id                        String                    @id @default(uuid())
  action                    String                    // e.g., 'UPDATE_SETTINGS', 'DELETE_USER', 'APPROVE_ASSET'
  module                    String                    // e.g., 'SETTINGS', 'USER', 'ASSET'
  description               String?                   // Human readable description
  oldValue                  String?                   @db.Text // JSON string of before state
  newValue                  String?                   @db.Text // JSON string of after state
  ipAddress                 String?
  userAgent                 String?
  userId                    String?
  user                      User?                     @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt                 DateTime                  @default(now())

  @@index([userId])
  @@index([createdAt])
}

model MirrorSource {
  id                        String                    @id @default(uuid())
  name                      String                    @unique
  displayName               String
  baseUrl                   String
  adapterType               String                    @default("GENERIC_WP")
  status                    String                    @default("ACTIVE")
  syncStatus                String                    @default("IDLE")
  lastSyncAt                DateTime?
  lastSyncDuration          Int?
  totalResources            Int                       @default(0)
  syncInterval              Int                       @default(3600)
  syncConfig                String?
  minPlanPriority           Int                       @default(1)
  iconUrl                   String?
  description               String?
  categories                MirrorCategory[]
  resources                 MirrorResource[]
  syncLogs                  SyncLog[]
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt
}

model MirrorCategory {
  id                        String                    @id @default(uuid())
  sourceId                  String
  source                    MirrorSource              @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  externalId                String
  name                      String
  slug                      String?
  parentExternalId          String?
  order                     Int                       @default(0)
  resourceCount             Int                       @default(0)
  resources                 MirrorResource[]
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt

  @@unique([sourceId, externalId])
}

model MirrorResource {
  id                        String                    @id @default(uuid())
  sourceId                  String
  source                    MirrorSource              @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  externalId                String
  categoryId                String?
  category                  MirrorCategory?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  title                     String
  description               String?                   @db.Text
  thumbnailUrl              String?
  contentUrl                String?
  tags                      String?
  externalData              String?                   @db.Text
  contentHtml               String?                   @db.Text
  resourceType              String                    @default("COURSE")
  viewCount                 Int                       @default(0)
  publishedAt               DateTime?
  syncedAt                  DateTime                  @default(now())
  contentHash               String?
  comments                  MirrorResourceComment[]
  likes                     MirrorResourceLike[]
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt

  @@unique([sourceId, externalId])
  @@index([sourceId, categoryId])
  @@index([title])
  @@index([syncedAt])
  @@index([contentHash])
}

model SyncLog {
  id                        String                    @id @default(uuid())
  sourceId                  String
  source                    MirrorSource              @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  type                      String
  status                    String
  startedAt                 DateTime                  @default(now())
  finishedAt                DateTime?
  duration                  Int?
  resourcesFound            Int                       @default(0)
  resourcesCreated          Int                       @default(0)
  resourcesUpdated          Int                       @default(0)
  resourcesDeleted          Int                       @default(0)
  error                     String?
  metadata                  String?
  createdAt                 DateTime                  @default(now())

  @@index([sourceId])
  @@index([startedAt])
}

model MirrorResourceComment {
  id                        String                    @id @default(uuid())
  content                   String
  resourceId                String
  resource                  MirrorResource            @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  userId                    String
  user                      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt

  @@index([resourceId])
  @@index([userId])
}

model MirrorResourceLike {
  id                        String                    @id @default(uuid())
  resourceId                String
  resource                  MirrorResource            @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  userId                    String
  user                      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt                 DateTime                  @default(now())

  @@unique([resourceId, userId])
}

model ManualStation {
  id                        String                    @id @default(uuid())
  name                      String                    @unique
  displayName               String
  status                    String                    @default("ACTIVE")
  totalResources            Int                       @default(0)
  minPlanPriority           Int                       @default(1)
  iconUrl                   String?
  description               String?
  categories                ManualCategory[]
  resources                 ManualResource[]
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt
}

model ManualCategory {
  id                        String                    @id @default(uuid())
  stationId                 String
  station                   ManualStation             @relation(fields: [stationId], references: [id], onDelete: Cascade)
  name                      String
  slug                      String?
  parentId                  String?
  parent                    ManualCategory?           @relation("ManualCategoryParent", fields: [parentId], references: [id], onDelete: SetNull)
  children                  ManualCategory[]          @relation("ManualCategoryParent")
  order                     Int                       @default(0)
  resourceCount             Int                       @default(0)
  resources                 ManualResource[]
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt

  @@index([stationId])
}

model ManualResource {
  id                        String                    @id @default(uuid())
  stationId                 String
  station                   ManualStation             @relation(fields: [stationId], references: [id], onDelete: Cascade)
  categoryId                String?
  category                  ManualCategory?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  title                     String
  description               String?                   @db.Text
  thumbnailUrl              String?
  contentUrl                String?
  tags                      String?
  contentHtml               String?                   @db.Text
  resourceType              String                    @default("COURSE")
  viewCount                 Int                       @default(0)
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt
  comments                  ManualResourceComment[]
  likes                     ManualResourceLike[]

  @@index([stationId, categoryId])
  @@index([title])
}

model ManualResourceComment {
  id                        String                    @id @default(uuid())
  resourceId                String
  resource                  ManualResource            @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  userId                    String
  user                      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  content                   String
  createdAt                 DateTime                  @default(now())

  @@index([resourceId])
  @@index([userId])
}

model ManualResourceLike {
  id                        String                    @id @default(uuid())
  resourceId                String
  resource                  ManualResource            @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  userId                    String
  user                      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt                 DateTime                  @default(now())

  @@unique([resourceId, userId])
  @@index([resourceId])
  @@index([userId])
}

model MicrosoftEmailAccount {
  id                        String                    @id @default(uuid())
  userId                    String
  user                      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  email                     String                    @unique
  password                  String?                   // Encrypted with enc:v1 when provided
  clientId                  String                    // Microsoft OAuth Client ID
  refreshToken              String                    @db.Text // OAuth2 Refresh Token (used to acquire access tokens)
  accessToken               String?                   @db.Text // Current active ephemeral access token
  tokenExpiresAt            DateTime?                 // Expiry timestamp of the current access token
  status                    String                    @default("ACTIVE") // 'ACTIVE', 'EXPIRED', 'ERROR'
  statusMessage             String?                   @db.Text

  // Anti-Ban & Safe Sending Configurations
  proxy                     String?                   // Proxy URL, e.g., http://user:pass@host:port
  userAgent                 String?                   @db.Text // Custom User-Agent
  dailyLimit                Int                       @default(50) // Max sends per day
  sentCountToday            Int                       @default(0) // Counter for today
  lastResetDate             DateTime                  @default(now()) // Daily limit reset tracker
  minDelay                  Int                       @default(5) // Min seconds delay between actions
  maxDelay                  Int                       @default(15) // Max seconds delay between actions

  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt

  @@index([userId])
}

model AiMessage {
  id                        String                    @id @default(uuid())
  userId                    String
  user                      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role                      String                    // 'user' or 'assistant'
  content                   String                    @db.Text
  reasoning                 String?                   @db.Text
  sessionId                 String                    @default("default")
  sessionTitle              String                    @default("New conversation")
  createdAt                 DateTime                  @default(now())

  @@index([userId, createdAt])
  @@index([userId, sessionId, createdAt])
  @@index([sessionId])
}

model NoteShare {
  id                        String                    @id @default(uuid())
  noteId                    String                    @unique
  userId                    String
  expiresAt                 DateTime?
  customText                String?                   @db.Text
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt
  note                      Note                      @relation(fields: [noteId], references: [id], onDelete: Cascade)
  user                      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([noteId])
  @@index([userId])
  @@index([expiresAt])
}

model AssetShare {
  id                        String                    @id @default(uuid())
  assetId                   String                    @unique
  userId                    String
  expiresAt                 DateTime?
  customText                String?                   @db.Text
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt
  asset                     Asset                     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  user                      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@index([userId])
  @@index([expiresAt])
}

model Banner {
  id                        String                    @id @default(uuid())
  title                     String
  subtitle                  String?                   @db.Text
  imageUrl                  String
  route                     String                    @default("/discussions")
  tag                       String?
  tagColor                  String?                   @default("bg-accent/15 text-accent border-accent/30")
  buttonText                String                    @default("绔嬪嵆鍙備笌")
  order                     Int                       @default(0)
  isActive                  Boolean                   @default(true)
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt

  @@index([isActive, order])
}

model AssetVersion {
  id                        String                    @id @default(uuid())
  assetId                   String
  asset                     Asset                     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  version                   String
  url                       String
  packageUrl                String?
  packageSize               Float?
  packageFilesList          String?                   @db.Text
  thumbnail                 String?
  size                      Float?

  // 鐗堟湰鐗瑰畾鐗堟潈涓庤鏍?  originality               String?                   @default("ORIGINAL")
  originalAuthor            String?
  originalLink              String?
  license                   String?                   @default("CC_BY")
  meshType                  String?                   @default("LOW_POLY")
  uvUnwrapped               Boolean                   @default(true)
  uvOverlapping             Boolean                   @default(false)
  pbrChannels               String?                   @db.Text
  rigged                    Boolean                   @default(false)
  gameReady                 Boolean                   @default(false)

  // 鐗堟湰鐗瑰畾鐩告満涓庢覆鏌撻厤缃?  defaultCameraPos          String?
  defaultCameraTarget       String?
  defaultEnvironment        String?                   @default("studio")
  defaultExposure           Float?                    @default(1.0)
  vertices                  Int?
  faces                     Int?
  materials                 Int?
  dimensions                String?
  maxTextureRes             Int?
  changeLog                 String?                   @db.Text
  userId                    String
  user                      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt                 DateTime                  @default(now())

  @@index([assetId])
  @@index([userId])
}

model AssetAnnotation {
  id                        String                    @id @default(uuid())
  assetId                   String
  asset                     Asset                     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  userId                    String
