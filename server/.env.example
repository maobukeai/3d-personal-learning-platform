# Server Port
PORT=3001

# JWT Secret (required, use a long random string in production)
JWT_SECRET=your-secret-key-change-this-in-production

# Database field encryption key for email account credentials and other stored secrets.
# Generate a stable production value with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DATABASE_ENCRYPTION_KEY=your-database-encryption-key-change-this-in-production

# Database (Prisma schema has MySQL provider configured)
# MySQL format: mysql://username:password@host:port/database_name?connection_limit=5&pool_timeout=20
DATABASE_URL="mysql://root:yourpassword@127.0.0.1:3306/learning_platform?connection_limit=5&pool_timeout=20"

# Environment (生产服务器必须设为 production)
NODE_ENV=production

# Frontend URL (for CORS，生产环境改为你的真实域名)
# 例如: FRONTEND_URL=https://yourdomain.com
FRONTEND_URL=http://localhost:5173

# Backend URL (for OAuth callbacks，生产环境改为你的后端真实域名)
# 例如: BACKEND_URL=https://api.yourdomain.com
BACKEND_URL=http://localhost:3001

# Reverse proxy and rate limits
# TRUST_PROXY=1 works for common Nginx -> Node deployments. Use 2 if a CDN
# such as Cloudflare sits in front of Nginx and requests are being grouped.
TRUST_PROXY=1
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=3000
AUTH_IP_RATE_LIMIT_MAX=200
AUTH_CREDENTIAL_RATE_LIMIT_MAX=20

# GitHub Token (optional, for higher API rate limits)
GITHUB_TOKEN=

# SMTP Configuration (optional, for email sending)
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_SECURE=true

# Minimum interval between direct-message email reminders for the same recipient
# and conversation. The first reminder is sent as soon as possible; messages
# received during this interval are merged into the next reminder.
# Set to 0 to email every unread message.
MESSAGE_EMAIL_COOLDOWN_MS=300000

# Retry interval after a queued direct-message reminder fails to send.
MESSAGE_EMAIL_RETRY_MS=60000

# How often the server sweeps the database for queued direct-message reminders
# that need to be scheduled after restarts or missed timers.
MESSAGE_EMAIL_SWEEP_MS=60000

# Alipay Configuration (optional, for payments)
# ALIPAY_APP_ID=
# ALIPAY_PRIVATE_KEY=
# ALIPAY_PUBLIC_KEY=
# ALIPAY_GATEWAY=https://openapi-sandbox.dl.alipaydev.com/gateway.do

# Redis Configuration (optional, defaults to redis://127.0.0.1:6379)
# REDIS_URL=redis://127.0.0.1:6379

# CORS Extra Origins (optional, comma-separated list of additional allowed CORS origins)
# CORS_EXTRA_ORIGINS=

# Initial seed passwords for Admin and Regular users (optional)
# ADMIN_INITIAL_PASSWORD=Admin_Secure_2026!
# USER_INITIAL_PASSWORD=User_Secure_2026!

# Symmetric encryption key for resource extracts (required for production)
# EXTRACT_ENCRYPTION_KEY=
