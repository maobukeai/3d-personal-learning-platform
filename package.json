{
  "name": "3d-personal-learning-platform",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "build:analyze": "vite build --mode analyze",
    "postbuild": "node scripts/assert-bundle-size.mjs",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:strict": "eslint . --max-warnings=0 && node scripts/assert-no-important.mjs",
    "check:no-important": "node scripts/assert-no-important.mjs",
    "format": "prettier --write src/",
    "prepare": "husky install",
    "test:unit": "vitest run",
    "test:unit:core": "vitest run --config vitest.core.config.ts --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@tiptap/extension-highlight": "^3.27.3",
    "@tiptap/extension-image": "^3.27.3",
    "@tiptap/extension-link": "^3.27.3",
    "@tiptap/extension-strike": "^3.27.3",
    "@tiptap/extension-table": "^3.27.3",
    "@tiptap/extension-table-cell": "^3.27.3",
    "@tiptap/extension-table-header": "^3.27.3",
    "@tiptap/extension-table-row": "^3.27.3",
    "@tiptap/extension-task-item": "^3.27.3",
    "@tiptap/extension-task-list": "^3.27.3",
    "@tiptap/extension-underline": "^3.27.3",
    "@tiptap/starter-kit": "^3.27.3",
    "@tiptap/vue-3": "^3.27.3",
    "@types/katex": "^0.16.8",
    "@types/marked": "^5.0.2",
    "@types/turndown": "^5.0.6",
    "axios": "^1.16.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.3",
    "gsap": "^3.15.0",
    "katex": "^0.17.0",
    "lucide-vue-next": "^1.0.0",
    "marked": "^18.0.5",
    "md-editor-v3": "^6.5.0",
    "mermaid": "^11.16.0",
    "mitt": "^3.0.1",
    "pinia": "^3.0.4",
    "qrcode": "^1.5.4",
    "radix-vue": "^1.9.17",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.184.0",
    "three-mesh-bvh": "^0.9.10",
    "turndown": "^7.2.4",
    "vue": "^3.5.32",
    "vue-i18n": "^11.4.2",
    "vue-router": "^5.0.6",
    "vuedraggable": "^4.1.0",
    "y-prosemirror": "^1.3.7",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.31"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^24.12.3",
    "@types/qrcode": "^1.5.6",
    "@types/three": "^0.184.1",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.10",
    "@vue/tsconfig": "^0.9.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-unused-imports": "^4.4.1",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^15.3.0",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.10",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.7"
  }
}
